local curFolderIdx = 1
local function getItemsDeep(folder)
	local res = {}
	for _, c in pairs(folder:GetChildren()) do
		if c:IsA("Tool") or c:IsA("HopperBin") or c:IsA("Accessory") then table.insert(res, c) end
		if c:IsA("Folder") or c:IsA("Model") or c:IsA("Configuration") then
			for _, i in pairs(getItemsDeep(c)) do table.insert(res, i) end
		end
	end
	return res
end

