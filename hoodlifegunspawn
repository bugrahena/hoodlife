	local function toggleAdmin()
		adminOpen = not adminOpen
		if adminOpen then
			adminFrame2.Position = UDim2.new(0.5,-265,0.5,-325)
			adminFrame2.Visible = true
			adminFrame2.Size = UDim2.new(0,510,0,0)
			TweenService:Create(adminFrame2, TweenInfo.new(0.26, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size=UDim2.new(0,530,0,650)}):Play()
			refreshKeys()
		else
			TweenService:Create(adminFrame2, TweenInfo.new(0.18, Enum.EasingStyle.Quint), {Size=UDim2.new(0,510,0,0)}):Play()
			task.wait(0.2)
			adminFrame2.Visible = false
		end
	end

