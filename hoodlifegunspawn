		if keyDatabase[ks] then kGenSt.Text=L.adminKeyExists kGenSt.TextColor3=Color3.fromRGB(205,85,85) return end
		local expT = selDur > 0 and (os.time()+selDur) or nil
		local uses = tonumber(usageInp.Text) or nil
		local target = targetInp.Text ~= "" and targetInp.Text or nil
		keyDatabase[ks] = {active=true, expireTime=expT, uses=uses, usedCount=0, targetPlayer=target}
		kGenSt.Text = L.adminCreated..ks
		kGenSt.TextColor3 = Color3.fromRGB(115,196,140)
		refreshKeys()
		task.wait(3) kGenSt.Text = ""
	end)

