local function addSnow(parent, count, zi)
	local list = {}
	for i = 1, count do
		local sf = mkFrame(parent, UDim2.new(0,math.random(2,5),0,math.random(2,5)), UDim2.new(math.random(0,100)/100,0,math.random(-10,110)/100,0), Color3.fromRGB(210,218,230), zi or 1, 10)
		sf.BackgroundTransparency = math.random(40,70)/100
		list[i] = {frame=sf, speed=math.random(40,130)/1000, drift=math.random(-20,20)/1000, posY=math.random(-10,110)/100, posX=math.random(0,100)/100}
	end
	return list
end

local function tickSnow(list, dt)
	for _, s in pairs(list) do
		s.posY += s.speed * dt
		s.posX += s.drift * dt
		if s.posY > 1.05 then s.posY = -0.05 s.posX = math.random(0,100)/100 end
		if s.posX < 0 then s.posX = 1 end
		if s.posX > 1 then s.posX = 0 end
		s.frame.Position = UDim2.new(s.posX,0,s.posY,0)
	end
end

