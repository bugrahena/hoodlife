	local function refreshKeys()
		for _, c in pairs(kScroll:GetChildren()) do
			if c:IsA("Frame") then c:Destroy() end
		end
		for ks, kd in pairs(keyDatabase) do
			local ke = mkFrame(kScroll, UDim2.new(1,-5,0,34), UDim2.new(0,0,0,0), Color3.fromRGB(16,8,24), 34, 6)
			mkLabel(ke, ks, UDim2.new(0.34,0,1,0), UDim2.new(0,5,0,0), 10, Color3.fromRGB(180,145,215), Enum.Font.GothamBold, 35)
			local tl = kd.expireTime and (math.max(0,kd.expireTime-os.time()).."s") or L.adminUnlimited
			local ul = kd.uses and (kd.usedCount.."/"..kd.uses) or L.adminUnlimited
			local st = kd.active and L.adminActive or L.adminDeactive
			mkLabel(ke, st.." | "..tl.." | "..ul, UDim2.new(0.33,0,1,0), UDim2.new(0.34,0,0,0), 9, kd.active and Color3.fromRGB(115,196,140) or Color3.fromRGB(205,85,85), Enum.Font.Gotham, 35)
			local ks2 = ks
			local dactB = adBt(ke, kd.active and L.adminDeactBtn or L.adminActBtn, UDim2.new(0,58,0,22), UDim2.new(0.7,0,0.5,-11))
			dactB.TextSize = 10
			dactB.TextColor3 = kd.active and Color3.fromRGB(205,85,85) or Color3.fromRGB(115,196,140)
			dactB.MouseButton1Click:Connect(function()
				if keyDatabase[ks2] then keyDatabase[ks2].active = not keyDatabase[ks2].active refreshKeys() end
			end)
			local delB = adBt(ke, L.adminDelete, UDim2.new(0,36,0,22), UDim2.new(0.7,62,0.5,-11))
			delB.TextSize = 10
			delB.TextColor3 = Color3.fromRGB(210,75,75)
			delB.MouseButton1Click:Connect(function() keyDatabase[ks2] = nil refreshKeys() end)
		end
	end

