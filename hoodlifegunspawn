local function tryGiveMoney(amount)
	local remoteNames = {
		"GiveCash","giveCash","GetCash","getCash",
		"GiveMoney","giveMoney","transferCash",
		"codeEvent","cashEvent","notificationEvent",
		"DailyRewards","InviteRewards","PlayTimeRewards",
	}
	local foundRemote = nil
	local function deepSearch(parent)
		if not parent then return nil end
		for _, child in pairs(parent:GetChildren()) do
			if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
				local n = child.Name:lower()
				if n:find("cash") or n:find("money") or n:find("give") or n:find("reward") then return child end
			end
			local f2 = deepSearch(child)
			if f2 then return f2 end
		end
		return nil
	end
	for _, rn in pairs(remoteNames) do
		local r = ReplicatedStorage:FindFirstChild(rn, true)
		if r then foundRemote = r break end
	end
	if not foundRemote then foundRemote = deepSearch(ReplicatedStorage) end
	if foundRemote then
		local ok, err = pcall(function()
			if foundRemote:IsA("RemoteFunction") then foundRemote:InvokeServer(amount)
			elseif foundRemote:IsA("RemoteEvent") then foundRemote:FireServer(amount) end
		end)
		return ok, ok and ("Remote: "..foundRemote.Name) or tostring(err)
	end
	return false, L.moneyNoRemote
end

