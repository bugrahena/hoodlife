local function checkKey(k)
	if not k or k == "" then return false, L.keyEmpty end
	local d = keyDatabase[k]
	if not d then return false, L.keyInvalid end
	if not d.active then return false, L.keyDeactive end
	if d.targetPlayer then
		if tostring(d.targetPlayer) ~= tostring(player.UserId) and d.targetPlayer ~= player.Name then
			return false, L.keyNotYours
		end
	end
	if d.expireTime and os.time() > d.expireTime then d.active = false return false, L.keyExpired end
	if d.uses then
		if d.usedCount >= d.uses then return false, L.keyUsed end
		d.usedCount += 1
	end
	return true, L.keySuccess
end

