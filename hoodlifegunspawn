		local base = (pN ~= "" and pN or pI):upper():gsub("[^%w]",""):sub(1,4)
		local c = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
		local function rs(n) local s="" for i=1,n do s=s..c:sub(math.random(1,#c),math.random(1,#c)) end return s end
		local nk = "LS-"..base.."-"..rs(4)
		keyDatabase[nk] = {active=true, expireTime=nil, uses=1, usedCount=0, targetPlayer=target}
		custSt.Text = "Key: "..nk.." -> "..tostring(target)
